# Copy to .env and adjust as needed.

# Generate a fresh key with:  python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me

# Set to false in production.
DJANGO_DEBUG=true

# Comma-separated. Inclua o IP/host da maquina servidora na rede interna.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Origens confiaveis para CSRF (incluir http://IP-SERVIDOR:8000 quando expor na rede).
DJANGO_CSRF_TRUSTED_ORIGINS=

# Backup Git privado.
BACKUP_GIT_REMOTE=https://github.com/DanielRangel27/backups.git
BACKUP_GIT_BRANCH=main
# Diretorio local onde o repositorio de backup sera clonado.
# BACKUP_GIT_DIR=
# Pasta dentro do repositorio remoto onde os arquivos de backup serao salvos.
BACKUP_GIT_TARGET_SUBDIR=procuradoria
# Dispara backup_git automaticamente ao criar/atualizar/deletar processos.
BACKUP_GIT_AUTO_ON_PROCESS_CHANGE=false
# Janela de cooldown (em segundos) entre backups automaticos de processo.
BACKUP_GIT_AUTO_COOLDOWN_SECONDS=120
# Opcional: arquivo para guardar o timestamp do ultimo backup automatico.
# BACKUP_GIT_AUTO_COOLDOWN_STATE_FILE=

# Nivel de log do Django.
DJANGO_LOG_LEVEL=INFO
